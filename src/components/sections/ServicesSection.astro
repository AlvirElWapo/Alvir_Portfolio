---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { content as siteContent, CONTACT } from "../../i18n/ui";

const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const services = siteContent[lang].services;
const proof = siteContent[lang].proof;
---

<BaseLayout
  title={t("meta.services.title")}
  description={t("meta.services.description")}
  sideBarActiveItemID="services"
>
  <!-- Header -->
  <div class="mb-8">
    <div class="text-3xl w-full font-bold mb-2">{t("services.title")}</div>
    <p class="text-lg opacity-90 max-w-2xl">{t("services.subtitle")}</p>
  </div>

  <!-- Service cards -->
  <div class="grid gap-4 md:grid-cols-2">
    {
      services.map((service) => (
        <div class="card bg-base-200 p-6 h-full">
          <h3 class="font-bold text-xl mb-2">{service.title}</h3>
          <p class="opacity-80">{service.desc}</p>
        </div>
      ))
    }
  </div>

  <!-- Proof: real work -->
  <div class="mt-12">
    <div class="text-3xl w-full font-bold mb-2">{t("proof.title")}</div>
    <p class="opacity-80 mb-5">{t("proof.intro")}</p>
    <div class="grid gap-4 md:grid-cols-2">
      {
        proof.map((item) => (
          <div class="card border border-base-300 p-6 h-full">
            <h3 class="font-bold text-lg mb-2">{item.title}</h3>
            <p class="text-sm opacity-80">{item.desc}</p>
          </div>
        ))
      }
    </div>
  </div>

  <!-- Closing CTA -->
  <div class="mt-12 card bg-base-200 p-8 text-center">
    <p class="text-lg mb-5 max-w-2xl mx-auto">{t("services.ctaText")}</p>
    <div>
      <a
        href={CONTACT.whatsapp}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-primary"
      >
        <span class="nf nf-fa-whatsapp mr-1"></span>
        {t("services.ctaButton")}
      </a>
    </div>
  </div>
</BaseLayout>
