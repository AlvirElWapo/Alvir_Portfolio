---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { CONTACT } from "../i18n/ui";

const { sideBarActiveItemID } = Astro.props;
const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const prefix = lang === "es" ? "" : "/en";

const items = [
  { id: "home", label: t("nav.home"), href: `${prefix}/` || "/", icon: "nf-fa-home" },
  { id: "services", label: t("nav.services"), href: `${prefix}/services`, icon: "nf-md-briefcase" },
  { id: "cv", label: t("nav.cv"), href: `${prefix}/cv`, icon: "nf-md-file_document_multiple" },
  { id: "blog", label: t("nav.blog"), href: `${prefix}/blog/`, icon: "nf-md-book_account" },
];

const homeHref = lang === "es" ? "/" : "/en/";
---

<ul class="menu grow shrink menu-md overflow-y-auto">
  {
    items.map((item) => {
      const href = item.id === "home" ? homeHref : item.href;
      const active = sideBarActiveItemID === item.id;
      return (
        <li>
          <a
            href={href}
            class={`py-3 text-base flex items-center gap-3 group ${active ? "bg-base-300" : ""}`}
          >
            <span
              class={`nf ${item.icon} text-2xl transition-transform duration-150 ${active ? "scale-110" : "group-hover:scale-125"}`}
            />
            <span
              class={`transition-all duration-300 ${
                active
                  ? "opacity-100 translate-x-0"
                  : "opacity-50 translate-x-[-10px] group-hover:opacity-100 group-hover:translate-x-0"
              }`}
            >
              {item.label}
            </span>
          </a>
        </li>
      );
    })
  }

  <li>
    <a
      href={CONTACT.whatsapp}
      target="_blank"
      rel="noopener noreferrer"
      class="py-3 text-base flex items-center gap-3 group"
    >
      <span class="nf nf-fa-whatsapp text-2xl transition-transform duration-150 group-hover:scale-125"></span>
      <span class="opacity-50 translate-x-[-10px] group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">
        {t("nav.contact")}
      </span>
    </a>
  </li>
</ul>
