---
import BlogList from "../../../../../components/sections/BlogList.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths({ paginate }) {
  const all_posts = await getCollection("blog");
  const all_tags = all_posts.flatMap((post) => post.data.tags || []);

  return all_tags.flatMap((tag) => {
    const filtred_posts = all_posts.filter((post) => post.data.tags?.includes(tag));
    return paginate(filtred_posts, { params: { tag }, pageSize: 10 });
  });
}

const { page } = Astro.props;
const { tag } = Astro.params;
---

<BlogList page={page} tag={tag} lang="en" />
